# BigSmoke backend production variables for Render
# Add these in Render Dashboard. Do not commit real values.

NODE_ENV=production

# Render injects PORT automatically. Do not set PORT unless you know why.
BACKEND_URL=https://bigsmokestyle-api.onrender.com
SITE_URL=https://bigsmokestyle.vercel.app
STORE_URL=https://bigsmokestyle.vercel.app
FRONTEND_URL=https://bigsmokestyle.vercel.app
ADMIN_URL=https://bigsmokestyle-admin.vercel.app
ALLOWED_ORIGINS=https://bigsmokestyle.vercel.app,https://bigsmokestyle-admin.vercel.app

# Security
JWT_SECRET=generate-a-random-64-character-secret
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD_HASH=generate-with-bcryptjs
ADMIN_PASSWORD=
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# Supabase Postgres for Prisma.
# Use the Supabase pooler/session connection string for Render:
# postgres://prisma.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase Storage/API for product images.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=product-images
SUPABASE_PRODUCTS_TABLE=products
SUPABASE_ORDERS_TABLE=orders

# Abacate Pay
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_API_URL=https://api.abacatepay.com/v2
ABACATEPAY_BASE_URL=https://api.abacatepay.com/v2
ABACATEPAY_CARD_MAX_INSTALLMENTS=6

# Store settings
STORE_CITY=Joao Pessoa
STORE_STATE=PB
STORE_ORIGIN_CEP=58000000
WHATSAPP_NUMBER=5583986494691

# Optional Stripe legacy fallback
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MOCK=false

# Optional WhatsApp integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_CONTENT_SID=
TWILIO_CUSTOMER_CONFIRMATION_ENABLED=false
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_TIMEOUT_MS=8000
