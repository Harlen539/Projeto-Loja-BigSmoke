{
  "name": "bigsmoke-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend Node.js da loja BigSmoke.",
  "main": "server.js",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore src/data --ignore src/uploads --ignore data --ignore uploads server.js",
    "test": "node --test",
    "setup": "node src/scripts/setup.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.105.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "sharp": "^0.33.5",
    "stripe": "^17.7.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^6.19.3"
  }
}
