# BigSmoke backend environment
# Copy to .env for local development. Never commit real secrets.

PORT=3000
NODE_ENV=development

# Public URLs
SITE_URL=http://localhost:3000
STORE_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Security
JWT_SECRET=generate-a-random-64-character-secret
ADMIN_EMAIL=admin@bigsmoke.local
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=change-this-local-password
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# Supabase Postgres through Prisma. Required for production.
DATABASE_URL=

# Supabase API and Storage. Required if product image upload uses Supabase Storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=product-images
SUPABASE_PRODUCTS_TABLE=products
SUPABASE_ORDERS_TABLE=orders

# Abacate Pay
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=
ABACATEPAY_API_URL=https://api.abacatepay.com/v2
ABACATEPAY_BASE_URL=https://api.abacatepay.com/v2
ABACATEPAY_CARD_MAX_INSTALLMENTS=6

# Optional Stripe legacy fallback
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MOCK=false

# Store settings
STORE_CITY=Joao Pessoa
STORE_STATE=PB
STORE_ORIGIN_CEP=58000000
WHATSAPP_NUMBER=5583986494691

# Optional WhatsApp integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_CONTENT_SID=
TWILIO_CUSTOMER_CONFIRMATION_ENABLED=false
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_TIMEOUT_MS=8000

# Local-only file fallback
BIGSMOKE_DATA_DIR=
BIGSMOKE_UPLOADS_DIR=
