# =============================================================
# BigSmoke Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha TODOS os valores.
# NUNCA comite o arquivo .env no repositório.
# =============================================================

PORT=3000
NODE_ENV=production
SITE_URL=https://SEU_DOMINIO.COM
STORE_URL=https://SEU_DOMINIO.COM/loja
ADMIN_URL=https://SEU_DOMINIO.COM/admin

# -------------------------------------------------------
# SEGURANÇA — OBRIGATÓRIO EM PRODUÇÃO
# -------------------------------------------------------

# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Mínimo 32 caracteres. NÃO use o valor de exemplo.
JWT_SECRET=GERE_UMA_CHAVE_ALEATORIA_LONGA_AQUI_MINIMO_64_CHARS

# E-mail do administrador
ADMIN_EMAIL=SEU_EMAIL_ADMIN@SEUDOMINIO.COM

# Use ADMIN_PASSWORD_HASH em produção (muito mais seguro).
# Gere com: node -e "require('bcryptjs').hash('SUA_SENHA_AQUI', 12).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=$2a$12$HASH_GERADO_AQUI

# Só use ADMIN_PASSWORD em desenvolvimento local (mínimo 12 caracteres).
# Em produção, deixe em branco e use ADMIN_PASSWORD_HASH acima.
ADMIN_PASSWORD=

# Origins permitidos para CORS (separe por vírgula).
# OBRIGATÓRIO em produção. Ex: https://meusite.com,https://admin.meusite.com
ALLOWED_ORIGINS=https://SEU_DOMINIO.COM,https://admin.SEU_DOMINIO.COM

# -------------------------------------------------------
# STRIPE
# -------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_SUA_CHAVE_SECRETA
STRIPE_WEBHOOK_SECRET=whsec_SUA_CHAVE_DE_WEBHOOK
STRIPE_MOCK=false
# STRIPE_PUBLISHABLE_KEY=pk_live_SUA_CHAVE_PUBLICAVEL

# -------------------------------------------------------
# SUPABASE — OBRIGATÓRIO EM PRODUÇÃO
# -------------------------------------------------------
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY
SUPABASE_BUCKET=product-images
SUPABASE_PRODUCTS_TABLE=products
SUPABASE_ORDERS_TABLE=orders

# -------------------------------------------------------
# LOJA / ENDEREÇO DE ORIGEM
# -------------------------------------------------------
STORE_CITY=Joao Pessoa
STORE_STATE=PB
STORE_ORIGIN_CEP=58000000
WHATSAPP_NUMBER=5583986494691

# -------------------------------------------------------
# TWILIO WHATSAPP (opcional)
# -------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+5583999999999
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_CONTENT_SID=
TWILIO_CUSTOMER_CONFIRMATION_ENABLED=true

WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_TIMEOUT_MS=8000

# -------------------------------------------------------
# DIRETÓRIOS (opcional — padrão: src/data e src/uploads)
# -------------------------------------------------------
BIGSMOKE_DATA_DIR=
BIGSMOKE_UPLOADS_DIR=
